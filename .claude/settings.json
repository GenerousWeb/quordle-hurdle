{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run typecheck:all && npm run lint && npm test",
            "async": true,
            "statusMessage": "Running typecheck, lint, and tests…",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
